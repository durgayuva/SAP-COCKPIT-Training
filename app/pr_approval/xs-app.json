{
 "welcomeFile": "/index.html",
 "authenticationMethod": "route",
 "routes": [
  {
   "source": "^/?odata/(.*)$",
   "target": "/odata/$1",
   "destination": "req-srv-api",
   "authenticationType": "xsuaa",
   "csrfProtection": true
  },
  {
   "source": "^/?odata/(.*)$",
   "target": "/odata/$1",
   "destination": "srv-api",
   "authenticationType": "xsuaa",
   "csrfProtection": true
  },
  {
   "source": "^(.*)$",
   "service": "html5-apps-repo-rt",
   "authenticationType": "xsuaa",
   "target": "$1"
  }
 ]
}
